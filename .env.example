# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Django settings module
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (production — используется в Docker)
DATABASE_URL=postgresql://USER:PASSWORD@db:5432/zakupki

# PostgreSQL (только для docker-compose)
POSTGRES_DB=zakupki
POSTGRES_USER=zakupki
POSTGRES_PASSWORD=

# Redis & Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email — вариант 1: вывод в консоль runserver (по умолчанию, Celery не нужен)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Email — вариант 2: Mailpit (локальный SMTP с веб-UI на http://localhost:8025)
# Установка: brew install mailpit  |  запуск: mailpit
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=localhost
# EMAIL_PORT=1025
# EMAIL_USE_TLS=False

# Email — вариант 3: настоящий SMTP (Gmail и др.)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

DEFAULT_FROM_EMAIL=noreply@zakupki.ru
ADMIN_EMAIL=admin@zakupki.ru
