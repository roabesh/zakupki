# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Django settings module
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (production — используется в Docker)
DATABASE_URL=postgresql://USER:PASSWORD@db:5432/zakupki

# PostgreSQL (только для docker-compose)
POSTGRES_DB=zakupki
POSTGRES_USER=zakupki
POSTGRES_PASSWORD=

# Redis & Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@zakupki.ru
ADMIN_EMAIL=admin@zakupki.ru
